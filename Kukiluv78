-- ======================== ระบบ RGB & REAL-TIME SYNC ========================
task.spawn(function()
    local bars = {" ", " ", "▂", "▃", "▄", "▅", "▆", "▇", "█"}
    while true do
        pcall(function() game:GetService("CoreGui").Rayfield.Main.Elements.BackgroundColor3 = Color3.fromHSV(tick() % 5 / 5, 1, 1) end)
        if IsPlaying and SongDuration > 0 then
            local elapsed = math.floor(tick() - StartTime)
            if elapsed <= SongDuration then
                local timeStr = string.format("%02d:%02d", math.floor(elapsed/60), elapsed%60) .. " / " .. string.format("%02d:%02d", math.floor(SongDuration/60), SongDuration%60)
                if MainTimeLabel then MainTimeLabel:Set("⏳ เวลาเล่น: " .. timeStr) end
                local v = ""
                for i = 1, 14 do
                    local loudness = (VisualSound and VisualSound.PlaybackLoudness) or 0
                    v = v .. bars[math.clamp(math.floor(loudness / 40) + 1, 1, #bars)]
                end
                VisualLabel:Set("🔊 [ " .. v .. " ]")
            else
                IsPlaying = false
                if MainTimeLabel then MainTimeLabel:Set("⏳ จบเพลง") end
            end
        end
        task.wait(0.05)
    end
end)
