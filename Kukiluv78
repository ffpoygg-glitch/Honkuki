local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local MarketplaceService = game:GetService("MarketplaceService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

-- [[ 💾 DATA SYSTEM ]] --
local FileName = "GuHon_Vault_V19.json"
local SavedSongs = {}
if isfile(FileName) then
    pcall(function() SavedSongs = HttpService:JSONDecode(readfile(FileName)) end)
end

local function SaveToFile()
    writefile(FileName, HttpService:JSONEncode(SavedSongs))
end

-- [[ 🛰️ CONFIG ]] --
local VehicleRemote = ReplicatedStorage:WaitForChild("RE"):WaitForChild("1NoMoto1rVehicle1s")
local CurrentID, IsPlaying, IsLooping = "", false, false
local StartTime, SongDuration, VisualSound = 0, 0, nil 

local Window = Rayfield:CreateWindow({
   Name = "GuHon V19 | VAULT FIX (By.Honkuki78)",
   LoadingTitle = "GuHon XD & Honkuki78",
   LoadingSubtitle = "Music System & Vault Fixed",
   ConfigurationSaving = { Enabled = false }
})

-- [[ 🛡️ LOGIC CLEAN ID ]] --
local function CleanID(str)
    if not str or type(str) ~= "string" then return nil end
    local num = str:match("%d+")
    if num and #num >= 6 then return num end
    return nil
end

-- [[ 📑 หน้าที่ 1: Bypass Logger (เหมือนเดิม) ]] --
local Tab1 = Window:CreateTab("Bypass Logger", 4483362458)
local ResLabel = Tab1:CreateLabel("🎯 สถานะ: พร้อมเจาะรหัส")

Tab1:CreateButton({
   Name = "🛰️ [ ดึงคนใกล้ที่สุด ]",
   Callback = function()
       local target, dist = nil, math.huge
       for _, p in pairs(game.Players:GetPlayers()) do
           if p ~= game.Players.LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
               local d = (game.Players.LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
               if d < dist then target, dist = p, d end
           end
       end
       if target then
           pcall(function()
               for _, obj in pairs(target.Character:GetDescendants()) do
                   if obj:IsA("Sound") then
                       local id = CleanID(obj.SoundId)
                       if id then CurrentID = id; ResLabel:Set("✅ เจาะได้แล้ว! ID: "..id); setclipboard(id); return end
                   end
               end
           end)
       end
   end
})

-- [[ 📑 หน้าที่ 2: Main Broadcast ]] --
local PlayTab = Window:CreateTab("Main Broadcast", 4483362458)
local SongTitle = PlayTab:CreateLabel("🎵 เพลง: -")
local TimeLabel = PlayTab:CreateLabel("⏳ เวลาเล่น: 00:00 / 00:00")

local function RunMusic(id)
    local playID = id or CurrentID
    if playID == "" then return end
    if VisualSound then VisualSound:Destroy() end
    VehicleRemote:FireServer("PickingScooterMusicText", playID, true)
    VisualSound = Instance.new("Sound", game:GetService("SoundService"))
    VisualSound.SoundId = "rbxassetid://"..playID
    VisualSound.Volume = 0 
    task.spawn(function()
        repeat task.wait(0.1) until VisualSound.TimeLength > 0
        SongDuration = math.floor(VisualSound.TimeLength)
        StartTime = tick()
        IsPlaying = true
        VisualSound:Play()
        local info = MarketplaceService:GetProductInfo(tonumber(playID))
        SongTitle:Set("🎵 เพลง: " .. info.Name)
    end)
end

PlayTab:CreateToggle({
   Name = "🔁 ระบบวนลูปเพลง (Auto Loop)",
   CurrentValue = false,
   Callback = function(v) IsLooping = v end,
})
PlayTab:CreateButton({ Name = "🔥 [ ส่งรีโมทเปิดเพลง ]", Callback = function() RunMusic() end })

-- [[ 📑 หน้าที่ 3: Music Vault (แก้บั๊กกดเซฟแล้วไม่ขึ้น) ]] --
local VaultTab = Window:CreateTab("Music Vault", 4483362458)
local SaveNameInput = ""
local SaveIDInput = ""

VaultTab:CreateInput({
   Name = "1. ใส่ชื่อเพลง",
   PlaceholderText = "ตั้งชื่อที่นี่...",
   Callback = function(t) SaveNameInput = t end,
})

VaultTab:CreateInput({
   Name = "2. ใส่ ID เพลง (หรือเจาะมาแล้วกดเซฟได้เลย)",
   PlaceholderText = "ใส่ ID ที่นี่...",
   Callback = function(t) SaveIDInput = CleanID(t) or t end,
})

-- ฟังก์ชันสร้างปุ่มเพลง (แยกออกมาเพื่อให้เรียกใช้ซ้ำได้)
local function AddSongButton(name, id)
    VaultTab:CreateButton({
        Name = "▶️ เล่น: " .. name, -- แสดงแค่ชื่อเพลงตามสั่ง
        Callback = function()
            CurrentID = id
            setclipboard(id)
            RunMusic(id)
            Window:SelectTab(PlayTab)
            Rayfield:Notify({Title = "Quick Play", Content = "กำลังเล่น: "..name, Duration = 2})
        end
    })
end

VaultTab:CreateButton({
   Name = "💾 [ บันทึกลงตู้เซฟ ]",
   Callback = function()
       local finalID = (SaveIDInput ~= "" and SaveIDInput) or CurrentID
       if SaveNameInput ~= "" and finalID ~= "" then
           -- เซฟลงข้อมูล
           table.insert(SavedSongs, {Name = SaveNameInput, ID = finalID})
           SaveToFile()
           
           -- สร้างปุ่มใหม่ให้เห็นทันที (แก้บั๊กที่มึงเจอ)
           AddSongButton(SaveNameInput, finalID)
           
           Rayfield:Notify({Title = "สำเร็จ!", Content = "บันทึกเพลง " .. SaveNameInput .. " แล้ว", Duration = 2})
       else
           Rayfield:Notify({Title = "ผิดพลาด", Content = "กรุณาใส่ชื่อเพลงและ ID ให้ครบ", Duration = 3})
       end
   end
})

VaultTab:CreateSection("รายการเพลงที่เซฟไว้")
-- โหลดเพลงเก่าที่เคยเซฟไว้
for _, item in pairs(SavedSongs) do
    AddSongButton(item.Name, item.ID)
end

-- [[ 🌈 RGB & Loop System ]] --
task.spawn(function()
    while true do
        local c = Color3.fromHSV(tick() % 5 / 5, 1, 1)
        pcall(function() game:GetService("CoreGui").Rayfield.Main.Elements.BackgroundColor3 = c end)
        if IsPlaying and SongDuration > 0 then
            local elapsed = tick() - StartTime
            TimeLabel:Set("⏳ เวลาเล่น: "..string.format("%02d:%02d", math.floor(elapsed/60), elapsed%60).." / "..string.format("%02d:%02d", math.floor(SongDuration/60), SongDuration%60))
            if elapsed >= SongDuration then
                if IsLooping then RunMusic() else IsPlaying = false end
            end
        end
        task.wait(0.1)
    end
end)
