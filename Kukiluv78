local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local MarketplaceService = game:GetService("MarketplaceService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

-- [[ 💾 DATA SYSTEM ]] --
local FileName = "GuHon_Vault_V19.json"
local SavedSongs = {}
if isfile(FileName) then
    pcall(function() SavedSongs = HttpService:JSONDecode(readfile(FileName)) end)
end
local function SaveToFile()
    writefile(FileName, HttpService:JSONEncode(SavedSongs))
end

-- [[ 🛰️ CONFIG & VARS ]] --
local VehicleRemote = ReplicatedStorage:WaitForChild("RE"):WaitForChild("1NoMoto1rVehicle1s")
local _JUNK = "ขยะ" 
local CurrentID, IsPlaying, IsLooping = "", false, false
local StartTime, SongDuration, VisualSound = 0, 0, nil 

-- [[ 🛡️ AUDIO MASKING (กันดึง) ]] --
local function MaskID(id)
    local encoded = ""
    for i = 1, #id do
        encoded = encoded .. string.format("%%%02X", string.byte(id:sub(i,i)))
    end
    local longJunk = _JUNK .. string.rep(_JUNK, 5) .. HttpService:GenerateGUID(false)
    return longJunk .. "&%69=00" .. encoded
end

-- [[ 🛡️ LOGIC CLEAN ID ]] --
local function CleanID(str)
    if not str or type(str) ~= "string" then return nil end
    local num = str:match("%d+")
    if num and #num >= 6 then return num end
    return nil
end

local Window = Rayfield:CreateWindow({
   Name = "GuHon V19 | SYNC (By.Honkuki78)",
   LoadingTitle = "GuHon XD & Honkuki78",
   LoadingSubtitle = "All Tabs Synced",
   ConfigurationSaving = { Enabled = false },
   Theme = "Default"
})

-- [[ 📑 หมวดหมู่ที่ 1: Bypass Logger (คงเดิม) ]] --
local Tab1 = Window:CreateTab("Bypass Logger", 4483362458)
local ResLabel = Tab1:CreateLabel("🎯 สถานะ: พร้อมเจาะรหัส")

Tab1:CreateButton({
   Name = "🛰️ [ ดึงคนใกล้ที่สุด ]",
   Callback = function()
       local target, dist = nil, math.huge
       for _, p in pairs(game.Players:GetPlayers()) do
           if p ~= game.Players.LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
               local d = (game.Players.LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
               if d < dist then target, dist = p, d end
           end
       end
       if target then
           pcall(function()
               for _, obj in pairs(target.Character:GetDescendants()) do
                   if obj:IsA("Sound") then
                       local id = CleanID(obj.SoundId)
                       if id then CurrentID = id; ResLabel:Set("✅ เจาะได้แล้ว! ID: "..id); setclipboard(id); return end
                   end
               end
           end)
       end
   end
})

-- [[ 📑 หมวดหมู่ที่ 2: Main Broadcast (ศูนย์กลางการเล่นเพลง) ]] --
local PlayTab = Window:CreateTab("Main Broadcast", 4483362458)
local SongTitle = PlayTab:CreateLabel("🎵 เพลง: -")
local TimeLabel = PlayTab:CreateLabel("⏳ เวลาเล่น: 00:00 / 00:00")

-- *** ฟังก์ชันศูนย์กลาง (ใช้ซิงค์กันทั้งสคริปต์) ***
local function RunMusic(id)
    if id then CurrentID = id end -- ถ้าส่ง ID มาใหม่ให้เปลี่ยน CurrentID ทันที
    if CurrentID == "" then return end
    
    if VisualSound then VisualSound:Destroy() end
    
    -- ยิงรีโมทแบบ Masking
    local maskedPayload = MaskID(CurrentID)
    VehicleRemote:FireServer("PickingScooterMusicText", maskedPayload, true)
    
    -- ระบบซิงค์สถานะ
    VisualSound = Instance.new("Sound", game:GetService("SoundService"))
    VisualSound.SoundId = "rbxassetid://"..CurrentID
    VisualSound.Volume = 0 
    task.spawn(function()
        repeat task.wait(0.1) until VisualSound.TimeLength > 0
        SongDuration = math.floor(VisualSound.TimeLength)
        StartTime = tick()
        IsPlaying = true
        VisualSound:Play()
        local info = MarketplaceService:GetProductInfo(tonumber(CurrentID))
        SongTitle:Set("🎵 เพลง: " .. info.Name)
    end)
end

PlayTab:CreateToggle({
   Name = "🔁 ระบบวนลูปเพลง (Auto Loop)",
   CurrentValue = false,
   Callback = function(v) IsLooping = v end,
})

PlayTab:CreateButton({ 
    Name = "🔥 [ ส่งรีโมทเปิดเพลง ]", 
    Callback = function() RunMusic() end 
})

PlayTab:CreateButton({
   Name = "⏹️ หยุดส่งรีโมท",
   Callback = function()
       IsPlaying = false
       VehicleRemote:FireServer("PickingScooterMusicText", "", true)
       if VisualSound then VisualSound:Stop() end
       TimeLabel:Set("⏳ เวลาเล่น: 00:00 / 00:00")
   end
})

-- [[ 📑 หมวดหมู่ที่ 3: Music Vault (ซิงค์การเล่นกับหมวด 2) ]] --
local VaultTab = Window:CreateTab("Music Vault", 4483362458)
local SaveNameInput, SaveIDInput = "", ""

VaultTab:CreateInput({ Name = "1. ใส่ชื่อเพลง", PlaceholderText = "ตั้งชื่อที่นี่...", Callback = function(t) SaveNameInput = t end })
VaultTab:CreateInput({ Name = "2. ใส่ ID เพลง", PlaceholderText = "ใส่ ID ที่นี่...", Callback = function(t) SaveIDInput = CleanID(t) or t end })

-- ฟังก์ชันสร้างปุ่มเล่นเพลงในตู้เซฟที่ซิงค์กับหมวด 2
local function AddSongButton(name, id)
    VaultTab:CreateButton({
        Name = "▶️ เล่น: " .. name,
        Callback = function()
            -- ซิงค์ข้อมูลและสั่งรันผ่านฟังก์ชันหลัก
            setclipboard(id)
            RunMusic(id) 
            
            -- สลับหน้าไปหมวด 2 เพื่อดูสถานะที่ซิงค์กัน
            Window:SelectTab(PlayTab)
            Rayfield:Notify({Title = "Synced Play", Content = "กำลังเล่นจากตู้เซฟ: "..name, Duration = 2})
        end
    })
end

VaultTab:CreateButton({
   Name = "💾 [ บันทึกลงตู้เซฟ ]",
   Callback = function()
       local finalID = (SaveIDInput ~= "" and SaveIDInput) or CurrentID
       if SaveNameInput ~= "" and finalID ~= "" then
           table.insert(SavedSongs, {Name = SaveNameInput, ID = finalID})
           SaveToFile()
           AddSongButton(SaveNameInput, finalID)
           Rayfield:Notify({Title = "สำเร็จ!", Content = "บันทึกและซิงค์ข้อมูลแล้ว", Duration = 2})
       end
   end
})

VaultTab:CreateSection("รายการเพลงที่เซฟไว้")
for _, item in pairs(SavedSongs) do AddSongButton(item.Name, item.ID) end

-- [[ ⏳ SYSTEM LOOP (เช็คสถานะการเล่นที่ซิงค์กัน) ]] --
task.spawn(function()
    while true do
        if IsPlaying and SongDuration > 0 then
            local elapsed = tick() - StartTime
            TimeLabel:Set("⏳ เวลาเล่น: "..string.format("%02d:%02d", math.floor(elapsed/60), elapsed%60).." / "..string.format("%02d:%02d", math.floor(SongDuration/60), SongDuration%60))
            if elapsed >= SongDuration then
                if IsLooping then RunMusic() else IsPlaying = false end
            end
        end
        task.wait(0.1)
    end
end)
