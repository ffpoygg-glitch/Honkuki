                local timeStr = string.format("%02d:%02d / %02d:%02d", math.floor(elapsed/60), elapsed%60, math.floor(SongDuration/60), SongDuration%60)
                if MainTimeLabel then MainTimeLabel:Set("⏳ เวลาเล่น: " .. timeStr) end
                local v = ""
                for i = 1, 14 do
                    local l = (VisualSound and VisualSound.PlaybackLoudness) or 0
                    v = v .. bars[math.clamp(math.floor(l / 40) + 1, 1, #bars)]
                end
                VisualLabel:Set("🔊 [ " .. v .. " ]")
            else
                IsPlaying = false; MainTimeLabel:Set("⏳ จบเพลง")
            end
        end
        task.wait(0.05)
    end
end)

