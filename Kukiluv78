local function CleanID(str)
    if not str or type(str) ~= "string" then return nil end
    local decoded = str
    while decoded:find("%%") do
        pcall(function() decoded = decoded:gsub("%%(%x%x)", function(hex) return string.char(tonumber(hex, 16)) end) end)
    end
    local allNumbers = {}
    for num in decoded:gmatch("%d+") do table.insert(allNumbers, num) end
    if #allNumbers > 0 then
        local rawId = allNumbers[#allNumbers]
        if #rawId >= 6 then return tostring(tonumber(rawId)) end
    end
    return nil
end

local function DeepHunt(target)
    if not target then return nil end
    local foundData = nil
    pcall(function()
        local paths = {target.Character, target:FindFirstChild("Backpack"), target:FindFirstChild("PlayerGui")}
        for _, path in pairs(paths) do
            if path then
                for _, obj in pairs(path:GetDescendants()) do
                    local content = ""
                    if obj:IsA("Sound") then content = obj.SoundId
                    elseif obj:IsA("StringValue") or obj:IsA("TextLabel") then
                        content = obj:IsA("StringValue") and obj.Value or obj.Text
                    end
                    local id = CleanID(content)
                    if id then foundData = {ID = id, Source = obj.Name} break end
                end
            end
            if foundData then break end
        end
    end)
    return foundData
end

