local fileName = "GuHon_Vault_Save.json"
local savedSongs = {}
local selectedSongIndex = nil
local vName, vID = "", "" 

local function SaveToFile()
    local s, content = pcall(function() return HttpService:JSONEncode(savedSongs) end)
    if s then writefile(fileName, content) end
end

local function LoadFromFile()
    if isfile(fileName) then
        local s, content = pcall(function() return HttpService:JSONDecode(readfile(fileName)) end)
        if s and type(content) == "table" then savedSongs = content end
    end
end

local songDropdown
local function UpdateDropdown()
    local options = {}
    for _, v in ipairs(savedSongs) do table.insert(options, v.name) end
    if songDropdown then songDropdown:Refresh(options, true) end
end

